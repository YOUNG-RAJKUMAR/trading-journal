//@version=5
indicator("Session Levels Indicator", overlay = true, max_labels_count = 500, max_lines_count = 500)

// INPUTS
i_lineWidth = input.int(2, "Line Width", minval = 1, maxval = 5)
i_labelSize = input.string("normal", "Label Size", options = ["tiny", "small", "normal", "large", "huge"])
i_asiaColor = input.color(color.new(color.blue, 0), "Asia Session Color")
i_londonColor = input.color(color.new(color.orange, 0), "London Session Color")
i_nyColor = input.color(color.new(color.purple, 0), "New York Session Color")
i_extendBars = input.int(10, "Extend Lines (bars after session)", minval = 0, maxval = 50)

// SESSION TIMES IN NEPAL TIME (UTC+5:45)
// Convert to exchange time - assuming chart is in exchange local time
// We'll work directly with Nepal Time by calculating offset
nepalOffset = 5 * 60 + 45 // 5 hours 45 minutes in minutes

// Get current time in Nepal Time
// Using timenow() which returns UNIX timestamp in milliseconds exchange time
// We need to adjust for Nepal Time
function getNepalTimeStamp() =>
    offsetMinutes = nepalOffset - (timezone * 60) // timezone is in minutes offset from UTC
    timenow() + offsetMinutes * 60 * 1000

// Convert timestamp to Nepal Time components
function getNepalTime(_timestamp) =>
    _date = time(_timestamp, "YYYYMMDD")
    _time = time(_timestamp, "HHmm")
    [_date, _time]

// Check if current time is within a session
function isInSession(_startTimeStr, _endTimeStr, _nowTime) =>
    // Handle sessions that cross midnight (like NY session)
    if _startTimeStr < _endTimeStr
        _nowTime >= _startTimeStr and _nowTime < _endTimeStr
    else
        _nowTime >= _startTimeStr or _nowTime < _endTimeStr

// Get today's date in Nepal Time
todayTimestamp = getNepalTimeStamp()
[todayDate, todayTime] = getNepalTime(todayTimestamp)

// Get yesterday's date for clearing old objects
yesterdayTimestamp = todayTimestamp - 24 * 60 * 60 * 1000
[yesterdayDate, _] = getNepalTime(yesterdayTimestamp)

// SESSION DEFINITIONS (Nepal Time)
asiaStart = "0545"
asiaEnd = "1445"
londonStart = "1245"
londonEnd = "2145"
nyStart = "1745"
nyEnd = "0245" // Crosses midnight

// Determine current session
isAsia = isInSession(asiaStart, asiaEnd, todayTime)
isLondon = isInSession(londonStart, londonEnd, todayTime)
isNewYork = isInSession(nyStart, nyEnd, todayTime)

// Initialize session tracking variables using var to preserve across bars
var float asiaHigh = na
var float asiaLow = na
var float londonHigh = na
var float londonLow = na
var float nyHigh = na
var float nyLow = na

var bool asiaStarted = false
var bool londonStarted = false
var bool nyStarted = false

var bool asiaEnded = false
var bool londonEnded = false
var bool nyEnded = false

// Reset session data at start of each Nepal day
if (todayDate[1] != todayDate[1][1]) // New day detected (compare with previous bar's date)
    asiaHigh := na
    asiaLow := na
    londonHigh := na
    londonLow := na
    nyHigh := na
    nyLow := na
    asiaStarted := false
    londonStarted := false
    nyStarted := false
    asiaEnded := false
    londonEnded := false
    nyEnded := false

// Session start detection
if not asiaStarted and isAsia
    asiaStarted := true
    asiaHigh := high
    asiaLow := low

if not londonStarted and isLondon
    londonStarted := true
    londonHigh := high
    londonLow := low

if not nyStarted and isNewYork
    nyStarted := true
    nyHigh := high
    nyLow := low

// Session end detection (when we exit the session)
if asiaStarted and not isAsia and not asiaEnded
    asiaEnded := true

if londonStarted and not isLondon and not londonEnded
    londonEnded := true

if nyStarted and not isNewYork and not nyEnded
    nyEnded := true

// Update high/low during active session
if isAsia
    asiaHigh := math.max(asiaHigh, high)
    asiaLow := math.min(asiaLow, low)

if isLondon
    londonHigh := math.max(londonHigh, high)
    londonLow := math.min(londonLow, low)

if isNewYork
    nyHigh := math.max(nyHigh, high)
    nyLow := math.min(nyLow, low)

// DRAW SESSION LINES AND LABELS
// Function to draw session levels
drawSessionLevels(_high, _low, _color, _labelText, _isActive, _hasEnded) =>
    if not na(_high) and not na(_low)
        // Draw high line
        highLine = line.new(
            x1 = bar_index - (_hasEnded ? 0 : 1),
            y1 = _high,
            x2 = bar_index + (not _hasEnded ? 0 : i_extendBars),
            y2 = _high,
            xloc = xloc.bar_index,
            extend = _hasEnded ? extend.right : extend.none,
            color = _color,
            width = i_lineWidth,
            style = line.style_solid
        )

        // Draw low line
        lowLine = line.new(
            x1 = bar_index - (_hasEnded ? 0 : 1),
            y1 = _low,
            x2 = bar_index + (not _hasEnded ? 0 : i_extendBars),
            y2 = _low,
            xloc = xloc.bar_index,
            extend = _hasEnded ? extend.right : extend.none,
            color = _color,
            width = i_lineWidth,
            style = line.style_solid
        )

        // Moving label above high
        if _isActive
            label.new(
                x = bar_index,
                y = _high,
                text = _labelText,
                style = label.style_label_left,
                color = _color,
                textcolor = color.white,
                size = i_labelSize,
                yloc = yloc.price
            )

        // Breakout detection after session ends
        if _hasEnded
            // Check for breakout above high
            breakoutAbove = high > _high and high[1] <= _high
            // Check for breakout below low
            breakoutBelow = low < _low and low[1] >= _low

            if breakoutAbove or breakoutBelow
                // Stop extending lines (handled by not using extend.right when breakout occurs)
                // We could add visual markers for breakouts here if needed
                pass

// Draw Asia session
drawSessionLevels(asiaHigh, asiaLow, i_asiaColor, "A", isAsia, asiaEnded)

// Draw London session
drawSessionLevels(londonHigh, londonLow, i_londonColor, "L", isLondon, londonEnded)

// Draw New York session
drawSessionLevels(nyHigh, nyLow, i_nyColor, "N", isNewYork, nyEnded)

// CLEAR PREVIOUS DAY'S OBJECTS (optional - Pine Script auto-clears based on max counts)
// We rely on the max_labels_count and max_lines_count settings in indicator declaration
// Plus our daily reset logic above

// Plot session status as debug (remove if not needed)
plotshape(isAsia, title="Asia Active", location=location.bottom, color=i_asiaColor, style=shape.triangleup, size=size.tiny)
plotshape(isLondon, title="London Active", location=location.bottom, color=i_londonColor, style=shape.triangleup, size=size.tiny)
plotshape(isNewYork, title="NY Active", location=location.bottom, color=i_nyColor, style=shape.triangleup, size=size.tiny)