//@version=5
indicator("Nepal Session High-Low Pro", overlay=true, max_lines_count=500, max_labels_count=500)

// ==========================================
// USER INPUTS
// ==========================================
grp_gen = "General Settings"
lineWidth = input.int(2, "Line Width", minval=1, maxval=5, group=grp_gen)
labelSize = input.string(size.normal, "Label Size", options=[size.tiny, size.small, size.normal, size.large, size.huge], group=grp_gen)
extDist   = input.int(50, "Extension Distance (Bars)", minval=0, group=grp_gen)

grp_asia = "Asia Session (05:45 - 14:45)"
colorAsia = input.color(#2962FF, "Asia Color", group=grp_asia)
asiaSessionTime = "0545-1445"

grp_lon = "London Session (12:45 - 21:45)"
colorLon = input.color(#E91E63, "London Color", group=grp_lon)
lonSessionTime = "1245-2145"

grp_ny = "New York Session (17:45 - 02:45)"
colorNY = input.color(#FF9800, "New York Color", group=grp_ny)
nySessionTime = "1745-0245"

TZ = "UTC+5:45"

// ==========================================
// LOGIC
// ==========================================
updateSession(sessTime, sessColor, sessLabel) =>
    var float hi = na
    var float lo = na
    var int hiBar = na
    var int loBar = na
    var line hiLine = na
    var line loLine = na
    var label hiLabel = na
    
    inSession = not na(time(timeframe.period, sessTime, TZ))
    isStart = inSession and na(inSession[1])
    isEnd = not inSession and inSession[1]

    if isStart
        hi := high
        lo := low
        hiBar := bar_index
        loBar := bar_index
    else if inSession
        if high > hi
            hi := high
            hiBar := bar_index
        if low < lo
            lo := low
            loBar := bar_index
    
    if isEnd
        hiLine := line.new(hiBar, hi, bar_index + extDist, hi, color=sessColor, width=lineWidth)
        loLine := line.new(loBar, lo, bar_index + extDist, lo, color=sessColor, width=lineWidth)
        hiLabel := label.new(hiBar, hi, sessLabel, color=sessColor, textcolor=color.white, style=label.style_label_down, size=labelSize)

    // Extension/Breakout
    if not inSession and not na(hi)
        if high > hi
            line.set_x2(hiLine, bar_index)
        else
            line.set_x2(hiLine, bar_index + extDist)
            
        if low < lo
            line.set_x2(loLine, bar_index)
        else
            line.set_x2(loLine, bar_index + extDist)

updateSession(asiaSessionTime, colorAsia, "A")
updateSession(lonSessionTime, colorLon, "L")
updateSession(nySessionTime, colorNY, "N")
