//@version=5
indicator("Nepal Session High-Low Segments", overlay=true, max_lines_count=500, max_labels_count=500)

// ==========================================
// INPUTS
// ==========================================
extDist = input.int(50, "Extension Distance (Bars)")
colorAsia = input.color(#2962FF, "Asia")
colorLon = input.color(#E91E63, "London")
colorNY = input.color(#FF9800, "New York")

TZ = "UTC+5:45"

// ==========================================
// LOGIC
// ==========================================
drawSession(sessTime, sessColor, sessLabel) =>
    var float hi = na
    var float lo = na
    var int hiBar = na
    var int loBar = na
    
    inSession = not na(time(timeframe.period, sessTime, TZ))
    isStart = inSession and not inSession[1]
    isEnd = not inSession and inSession[1]

    if isStart
        hi := high
        lo := low
        hiBar := bar_index
        loBar := bar_index
    else if inSession
        if high > hi
            hi := high
            hiBar := bar_index
        if low < lo
            lo := low
            loBar := bar_index
    
    if isEnd
        // Use line.new to create independent, non-connecting segments
        line.new(hiBar, hi, bar_index + extDist, hi, color=sessColor, width=2)
        line.new(loBar, lo, bar_index + extDist, lo, color=sessColor, width=2)
        label.new(hiBar, hi, sessLabel, color=sessColor, textcolor=color.white, style=label.style_label_down)

drawSession("0545-1445", colorAsia, "A")
drawSession("1245-2145", colorLon, "L")
drawSession("1745-0245", colorNY, "N")
