//@version=5
indicator("SESSION HIGH LOW - Current Day Only", overlay=true)

timezone = "Asia/Kathmandu"

// === Styling Inputs ===
lineWidth   = input.int(2, "Line Width", minval=1, maxval=5, group="General Styling")
labelSize   = input.string(size.small, "Label Size", options=[size.tiny, size.small, size.normal, size.large], group="General Styling")

colorAsia   = input.color(color.blue, "Asia Color", group="Colors")
colorLondon = input.color(color.red, "London Color", group="Colors")
colorNY     = input.color(color.green, "NY Color", group="Colors")

// === Session Time Inputs ===
session_asia   = input.session("0545-1445", "Asia Session", group="Sessions")     
session_london = input.session("1245-2145", "London Session", group="Sessions") 
session_ny     = input.session("1745-0245", "New York Session", group="Sessions") 

// === Day Change Logic (Resetting) ===
var int prevDayKey = na
currentDayKey = year * 10000 + month * 100 + dayofmonth
isNewDay = currentDayKey != prevDayKey

// === Session Variables ===
var float asiaHigh = na, var float asiaLow = na
var line asiaHLine = na, var line asiaLLine = na
var label asiaLbl = na

var float lonHigh = na, var float lonLow = na
var line lonHLine = na, var line lonLLine = na
var label lonLbl = na

var float nyHigh = na, var float nyLow = na
var line nyHLine = na, var line nyLLine = na
var label nyLbl = na

// Cleanup function for new day
if isNewDay
    line.delete(asiaHLine), line.delete(asiaLLine), label.delete(asiaLbl)
    line.delete(lonHLine), line.delete(lonLLine), label.delete(lonLbl)
    line.delete(nyHLine), line.delete(nyLLine), label.delete(nyLbl)
    prevDayKey := currentDayKey

// === Utility Function for Line End ===
// If the level hasn't been broken yet, the line continuously extends to the
// current bar (grows in real time). Once broken, it freezes at the break bar.
f_set_line_end(line_id, breakBar, startX) =>
    int endBar = na(breakBar) ? bar_index : (breakBar - 1)
    if endBar < startX
        endBar := startX
    line.set_xy2(line_id, endBar, line.get_price(line_id, line.get_x1(line_id)))

// === Asia Session Logic ===
inAsia = not na(time(timeframe.period, session_asia, timezone))
var int asiaHighBreak = na, var int asiaLowBreak = na
var bool asiaHBroken = false, var bool asiaLBroken = false

if inAsia and not inAsia[1]
    asiaHigh := high, asiaLow := low
    asiaHBroken := false, asiaLBroken := false
    asiaHighBreak := na, asiaLowBreak := na
    asiaHLine := line.new(bar_index, high, bar_index + 1, high, color=colorAsia, width=lineWidth)
    asiaLLine := line.new(bar_index, low, bar_index + 1, low, color=colorAsia, width=lineWidth)
    asiaLbl := label.new(bar_index, high, "A", color=colorAsia, style=label.style_label_up, yloc=yloc.abovebar, textcolor=color.white, size=labelSize)
else if inAsia
    asiaHigh := math.max(asiaHigh, high)
    asiaLow := math.min(asiaLow, low)

if not asiaHBroken and high > asiaHigh
    asiaHBroken := true, asiaHighBreak := bar_index
if not asiaLBroken and low < asiaLow
    asiaLBroken := true, asiaLowBreak := bar_index

if not na(asiaHLine)
    line.set_xy1(asiaHLine, line.get_x1(asiaHLine), asiaHigh)
    f_set_line_end(asiaHLine, asiaHighBreak, line.get_x1(asiaHLine))
    line.set_xy1(asiaLLine, line.get_x1(asiaLLine), asiaLow)
    f_set_line_end(asiaLLine, asiaLowBreak, line.get_x1(asiaLLine))
    label.set_xy(asiaLbl, line.get_x1(asiaHLine), asiaHigh)

// === London Session Logic ===
inLon = not na(time(timeframe.period, session_london, timezone))
var int lonHighBreak = na, var int lonLowBreak = na
var bool lonHBroken = false, var bool lonLBroken = false

if inLon and not inLon[1]
    lonHigh := high, lonLow := low
    lonHBroken := false, lonLBroken := false
    lonHighBreak := na, lonLowBreak := na
    lonHLine := line.new(bar_index, high, bar_index + 1, high, color=colorLondon, width=lineWidth)
    lonLLine := line.new(bar_index, low, bar_index + 1, low, color=colorLondon, width=lineWidth)
    lonLbl := label.new(bar_index, high, "L", color=colorLondon, style=label.style_label_up, yloc=yloc.abovebar, textcolor=color.white, size=labelSize)
else if inLon
    lonHigh := math.max(lonHigh, high)
    lonLow := math.min(lonLow, low)

if not lonHBroken and high > lonHigh
    lonHBroken := true, lonHighBreak := bar_index
if not lonLBroken and low < lonLow
    lonLBroken := true, lonLowBreak := bar_index

if not na(lonHLine)
    line.set_xy1(lonHLine, line.get_x1(lonHLine), lonHigh)
    f_set_line_end(lonHLine, lonHighBreak, line.get_x1(lonHLine))
    line.set_xy1(lonLLine, line.get_x1(lonLLine), lonLow)
    f_set_line_end(lonLLine, lonLowBreak, line.get_x1(lonLLine))
    label.set_xy(lonLbl, line.get_x1(lonHLine), lonHigh)

// === NY Session Logic ===
inNY = not na(time(timeframe.period, session_ny, timezone))
var int nyHighBreak = na, var int nyLowBreak = na
var bool nyHBroken = false, var bool nyLBroken = false

if inNY and not inNY[1]
    nyHigh := high, nyLow := low
    nyHBroken := false, nyLBroken := false
    nyHighBreak := na, nyLowBreak := na
    nyHLine := line.new(bar_index, high, bar_index + 1, high, color=colorNY, width=lineWidth)
    nyLLine := line.new(bar_index, low, bar_index + 1, low, color=colorNY, width=lineWidth)
    nyLbl := label.new(bar_index, high, "N", color=colorNY, style=label.style_label_up, yloc=yloc.abovebar, textcolor=color.white, size=labelSize)
else if inNY
    nyHigh := math.max(nyHigh, high)
    nyLow := math.min(nyLow, low)

if not nyHBroken and high > nyHigh
    nyHBroken := true, nyHighBreak := bar_index
if not nyLBroken and low < nyLow
    nyLBroken := true, nyLowBreak := bar_index

if not na(nyHLine)
    line.set_xy1(nyHLine, line.get_x1(nyHLine), nyHigh)
    f_set_line_end(nyHLine, nyHighBreak, line.get_x1(nyHLine))
    line.set_xy1(nyLLine, line.get_x1(nyLLine), nyLow)
    f_set_line_end(nyLLine, nyLowBreak, line.get_x1(nyLLine))
    label.set_xy(nyLbl, line.get_x1(nyHLine), nyHigh)
