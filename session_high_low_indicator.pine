//@version=5
indicator("Nepal Session High-Low with Wick Lines", overlay=true, max_lines_count=500, max_labels_count=500)

// ==========================================
// USER INPUTS
// ==========================================
grp_gen = "General Settings"
lineWidth = input.int(2, "Line Width", minval=1, maxval=5, group=grp_gen)
labelSize = input.string(size.normal, "Label Size", options=[size.tiny, size.small, size.normal, size.large, size.huge], group=grp_gen)
extDist   = input.int(5, "Extension Distance (Bars)", minval=0, group=grp_gen, tooltip="Distance to extend lines after session ends")

grp_asia = "Asia Session (05:45 - 14:45)"
colorAsia = input.color(color.new(#2962FF, 0), "Asia Color", group=grp_asia)
asiaSessionTime = "0545-1445"

grp_lon = "London Session (12:45 - 21:45)"
colorLon = input.color(color.new(#E91E63, 0), "London Color", group=grp_lon)
lonSessionTime = "1245-2145"

grp_ny = "New York Session (17:45 - 02:45)"
colorNY = input.color(color.new(#FF9800, 0), "New York Color", group=grp_ny)
nySessionTime = "1745-0245"

// Timezone constant
TZ = "UTC+5:45"

// ==========================================
// TYPES & STORAGE
// ==========================================
type SessionData
    float high = na
    float low = na
    int highBar = na
    int lowBar = na
    line highLine = na
    line lowLine = na
    label highLabel = na
    bool isActive = false
    bool highBroken = false
    bool lowBroken = false

// Persistent variables for sessions
var asia = SessionData.new()
var lon  = SessionData.new()
var ny   = SessionData.new()

// Array to track objects for deletion
var line[] allLines = array.new_line()
var label[] allLabels = array.new_label()

// ==========================================
// HELPER FUNCTIONS
// ==========================================

// Check if a new day has started in Nepal Time
isNewDay() =>
    d = time("D", TZ)
    ta.change(d)

// Clean up all objects from previous days
cleanupObjects() =>
    if array.size(allLines) > 0
        for i = 0 to array.size(allLines) - 1
            line.delete(array.get(allLines, i))
        array.clear(allLines)
    if array.size(allLabels) > 0
        for i = 0 to array.size(allLabels) - 1
            label.delete(array.get(allLabels, i))
        array.clear(allLabels)

// Update session logic
updateSession(SessionData s, string sessTime, color sessColor, string sessLabel) =>
    inSession = not na(time(timeframe.period, sessTime, TZ))
    isStart = inSession and not s.isActive
    
    if isStart
        s.isActive := true
        s.high := high
        s.low := low
        s.highBar := bar_index
        s.lowBar := bar_index
        s.highBroken := false
        s.lowBroken := false
        
    else if inSession
        // Update High/Low
        if high > s.high
            s.high := high
            s.highBar := bar_index
            
        if low < s.low
            s.low := low
            s.lowBar := bar_index
            
    else if s.isActive
        // Session just ended
        s.isActive := false
        
        // Create lines and labels only when session is finished to ensure they are perfectly horizontal
        s.highLine := line.new(s.highBar, s.high, bar_index + extDist, s.high, color=sessColor, width=lineWidth)
        s.lowLine := line.new(s.lowBar, s.low, bar_index + extDist, s.low, color=sessColor, width=lineWidth)
        s.highLabel := label.new(s.highBar, s.high, sessLabel, color=sessColor, textcolor=color.white, style=label.style_label_down, size=labelSize)
        
        array.push(allLines, s.highLine)
        array.push(allLines, s.lowLine)
        array.push(allLabels, s.highLabel)
        
    // Extension & Breakout Logic (only after session ends)
    if not na(s.high) and not s.isActive
        // High Line
        if not s.highBroken
            if high > s.high
                s.highBroken := true
                line.set_x2(s.highLine, bar_index)
            else
                line.set_x2(s.highLine, bar_index + extDist)
        
        // Low Line
        if not s.lowBroken
            if low < s.low
                s.lowBroken := true
                line.set_x2(s.lowLine, bar_index)
            else
                line.set_x2(s.lowLine, bar_index + extDist)

// ==========================================
// MAIN EXECUTION
// ==========================================

// Check for new day and cleanup
if isNewDay()
    cleanupObjects()
    // Reset session states for the new day
    asia := SessionData.new()
    lon  := SessionData.new()
    ny   := SessionData.new()

// Update each session
updateSession(asia, asiaSessionTime, colorAsia, "A")
updateSession(lon, lonSessionTime, colorLon, "L")
updateSession(ny, nySessionTime, colorNY, "N")
