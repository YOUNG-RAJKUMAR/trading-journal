//@version=5
indicator("Nepal Session High-Low Segments", overlay=true, max_lines_count=500)

// ==========================================
// INPUTS
// ==========================================
extDist = input.int(50, "Extension Distance (Bars)")
colorAsia = input.color(#2962FF, "Asia")
colorLon = input.color(#E91E63, "London")
colorNY = input.color(#FF9800, "New York")
showLabels = input.bool(true, "Show Session Labels")

TZ = "UTC+5:45"

// ==========================================
// SESSION DEFINITIONS
// ==========================================
sessions = [
    {id: "asia",  start: input.time(timestamp("01 Jan 2023 05:45 +0000"), "Asia Start",  session=true),  end: input.time(timestamp("01 Jan 2023 14:45 +0000"), "Asia End",    session=true)},
    {id: "london", start: input.time(timestamp("01 Jan 2023 12:45 +0000"), "London Start", session=true), end: input.time(timestamp("01 Jan 2023 21:45 +0000"), "London End",   session=true)},
    {id: "newyork", start: input.time(timestamp("01 Jan 2023 17:45 +0000"), "NY Start",   session=true), end: input.time(timestamp("02 Jan 2023 02:45 +0000"), "NY End",     session=true)}
]

// ==========================================
// STATE TRACKING: [sessionIndex][dayOffset: 0=today, 1=yesterday]
// ==========================================
// For each session and day (today/yesterday), track:
// - The high/low price level achieved during the session
// - The bar index where that high/low occurred
// - Whether the session has ended
// - Break detection against completed levels
var float[][] sessionHighLevel = array.new_float(3, 2, na)   // Price level of session high/low
var int[][] sessionHighLevelBar = array.new_int(3, 2, na)   // Bar where session high/low occurred
var float[][] sessionLowLevel = array.new_float(3, 2, na)
var int[][] sessionLowLevelBar = array.new_int(3, 2, na)
var bool[][] sessionEnded = array.new_bool(3, 2, false)    // Has session ended?
var bool[][] sessionBrokenHigh = array.new_bool(3, 2, false)// Has price broken above completed high?
var bool[][] sessionBrokenLow = array.new_bool(3, 2, false) // Has price broken below completed low?
var int[][] sessionBreakHighBar = array.new_int(3, 2, na)   // Bar where high was broken
var int[][] sessionBreakLowBar = array.new_int(3, 2, na)    // Bar where low was broken

// ==========================================
// HELPERS
// ==========================================
// Get session index from session id
getSessIdx(sessId) =>
    sessId == "asia" ? 0 : sessId == "london" ? 1 : 2

// Get session start/end times in timezone
getSessionStart(sessId) =>
    time(timeframe.period, sessId, TZ)

getSessionEnd(sessId) =>
    time(timeframe.period, sessId, TZ)

// Determine if current bar is in session
isInSession(sessId) =>
    sessStart = getSessionStart(sessId)
    sessEnd = getSessionEnd(sessId)
    // Handle overnight sessions (e.g., NY session)
    isOvernight = sessStart > sessEnd
    isOvernight ?
        (time >= sessStart or time < sessEnd) :
        (time >= sessStart and time < sessEnd)

// ==========================================
// MAIN PROCESSING
// ==========================================
// Determine today/yesterday based on Nepal time (UTC+5:45)
nepalOffset = 5.75 * 3600 * 1000
timeMs = time * 1000 + nepalOffset
todayStart = timestamp(year(timeMs), month(timeMs), dayofmonth(timeMs), 0, 0, 0)
yesterdayStart = todayStart - 24 * 60 * 60 * 1000

// Process each session
for [sIdx, sess] in sessions
    sessId = sess.id
    sessStart = getSessionStart(sessId)
    sessEnd = getSessionEnd(sessId)

    // Handle overnight sessions
    isOvernight = sessStart > sessEnd

    // Determine if currently in session
    inSess = isInSession(sessId)

    // Get today/yesterday session state
    todayHighLevel = sessionHighLevel[sIdx][0]
    todayLowLevel = sessionLowLevel[sIdx][0]
    yesterdayHighLevel = sessionHighLevel[sIdx][1]
    yesterdayLowLevel = sessionLowLevel[sIdx][1]

    bool todaySessionJustEnded = false
    bool yesterdaySessionJustEnded = false

    if inSess
        // We're in the session - update session high/low tracking
        if todayHighLevel == na
            // Session just started today
            sessionHighLevel[sIdx][0] := high
            sessionHighLevelBar[sIdx][0] := bar_index
            sessionLowLevel[sIdx][0] := low
            sessionLowLevelBar[sIdx][0] := bar_index
        else
            // Session ongoing - update if new high/low found
            if high > todayHighLevel
                sessionHighLevel[sIdx][0] := high
                sessionHighLevelBar[sIdx][0] := bar_index
            if low < todayLowLevel
                sessionLowLevel[sIdx][0] := low
                sessionLowLevelBar[sIdx][0] := bar_index
    else
        // We're NOT in session
        // Check if session just ended (was in session in previous bar)
        // Simplified: if we have session level data and session just ended
        if todayHighLevel != na  // We have data for today's session
            // In a more complete implementation, we'd check if we JUST exited
            // For now, we'll assume session ended if we have data and are not in session
            // A proper implementation would track previous inSession state
            todaySessionJustEnded := true

        if todaySessionJustEnded
            // Mark session as ended
            sessionEnded[sIdx][0] := true
            // Initialize break tracking for this completed session
            sessionBrokenHigh[sIdx][0] := false
            sessionBrokenLow[sIdx][0] := false
            sessionBreakHighBar[sIdx][0] := na
            sessionBreakLowBar[sIdx][0] := na

    // ==========================================
    // BREAK DETECTION FOR COMPLETED SESSIONS
    // ==========================================
    // Check today's completed session for breaks
    if todayHighLevel != na and sessionEnded[sIdx][0]
        // Upside break: price > completed session high level
        if not sessionBrokenHigh[sIdx][0] and high > todayHighLevel
            sessionBrokenHigh[sIdx][0] := true
            sessionBreakHighBar[sIdx][0] := bar_index
        // Downside break: price < completed session low level
        if not sessionBrokenLow[sIdx][0] and low < todayLowLevel
            sessionBrokenLow[sIdx][0] := true
            sessionBreakLowBar[sIdx][0] := bar_index

    // ==========================================
    // CALCULATE VALUES FOR PLOTTING
    // ==========================================
    // Function to get plot value for a session level
    getSessionPlotValue(sessionLevel, sessionLevelBar, isBroken, breakBar, extDist) =>
        if na(sessionLevel) or na(sessionLevelBar)
            na
        else
            // Calculate where the line should end
            // If broken: end at break bar
            // If not broken: end at session bar + extension distance
            lineEndBar = isBroken and not na(breakBar) ? breakBar : sessionLevelBar + extDist

            // Show value if current bar is between session bar and line end bar
            if bar_index >= sessionLevelBar and bar_index <= lineEndBar
                sessionLevel
            else
                na

    // Plot today's sessions (solid lines)
    plotTodayHigh = getSessionPlotValue(
        todayHighLevel,
        sessionHighLevelBar[sIdx][0],
        sessionBrokenHigh[sIdx][0],
        sessionBreakHighBar[sIdx][0],
        extDist
    )

    plotTodayLow = getSessionPlotValue(
        todayLowLevel,
        sessionLowLevelBar[sIdx][0],
        sessionBrokenLow[sIdx][0],
        sessionBreakLowBar[sIdx][0],
        extDist
    )

    // Plot with appropriate colors and styles
    // Today: solid lines
    plot(plotTodayHigh, title=sessId + " Today High",
         color=sessId=="asia" ? colorAsia : sessId=="london" ? colorLon : colorNY,
         linewidth=2, trackprice=false, offset=0, editable=true, style=line.style_solid)

    plot(plotTodayLow, title=sessId + " Today Low",
         color=sessId=="asia" ? colorAsia : sessId=="london" ? colorLon : colorNY,
         linewidth=2, trackprice=false, offset=0, editable=true, style=line.style_solid)

    # ==========================================
    # PLOT YESTERDAY'S SESSIONS (DASHED LINES)
    # ==========================================
    plotYesterdayHigh = getSessionPlotValue(
        yesterdayHighLevel,
        sessionHighLevelBar[sIdx][1],
        sessionBrokenHigh[sIdx][1],
        sessionBreakHighBar[sIdx][1],
        extDist
    )

    plotYesterdayLow = getSessionPlotValue(
        yesterdayLowLevel,
        sessionLowLevelBar[sIdx][1],
        sessionBrokenLow[sIdx][1],
        sessionBreakLowBar[sIdx][1],
        extDist
    )

    # Yesterday: dashed lines
    plot(plotYesterdayHigh, title=sessId + " Yesterday High",
         color=sessId=="asia" ? colorAsia : sessId=="london" ? colorLon : colorNY,
         linewidth=2, trackprice=false, offset=0, editable=true, style=line.style_dashed)

    plot(plotYesterdayLow, title=sessId + " Yesterday Low",
         color=sessId=="asia" ? colorAsia : sessId=="london" ? colorLon : colorNY,
         linewidth=2, trackprice=false, offset=0, editable=true, style=line.style_dashed)

    # ==========================================
    # OPTIONAL: SESSION LABELS
    # ==========================================
    if showLabels
        # Label for today's session high (at the start point)
        if not na(todayHighLevel) and bar_index == sessionHighLevelBar[sIdx][0]
            label.new(bar_index, todayHighLevel, sessId + " H",
                     color=sessId=="asia" ? colorAsia : sessId=="london" ? colorLon : colorNY,
                     style=label.style_label_left, textcolor=color.white, size=size.tiny)

        # Label for today's session low (at the start point)
        if not na(todayLowLevel) and bar_index == sessionLowLevelBar[sIdx][0]
            label.new(bar_index, todayLowLevel, sessId + " L",
                     color=sessId=="asia" ? colorAsia : sessId=="london" ? colorLon : colorNY,
                     style=label.style_label_left, textcolor=color.white, size=size.tiny)

// ==========================================
// NOTE ON STATE MANAGEMENT
// ==========================================
// This implementation uses a simplified approach to detect when sessions end.
// For production use, you would want to properly track the previous bar's
// in-session state to accurately detect session boundaries.
//
// The core logic is:
// 1. During session: track session high/low and where they occur
// 2. When session ends: save these as completed session levels
// 3. After session ends: watch for breaks of these completed levels
// 4. Display lines from session high/low point to either:
    //    - session end bar + extDist (if not broken)
//    - break bar (if broken)
// 5. Only show line while current bar is within this range