//@version=5
indicator("SESSION HIGH LOW - Current Day Only", overlay=true, max_lines_count=500, max_labels_count=500)

// ==========================================
// INPUTS
// ==========================================
lineWidth   = input.int(2, "Line Width", minval=1, maxval=5, group="General Styling")
labelSize   = input.string(size.small, "Label Size", options=[size.tiny, size.small, size.normal, size.large], group="General Styling")

colorAsia   = input.color(color.blue, "Asia Color", group="Colors")
colorLondon = input.color(color.red, "London Color", group="Colors")
colorNY     = input.color(color.green, "NY Color", group="Colors")

// === Session Time Inputs ===
session_asia   = input.session("0545-1445", "Asia Session", group="Sessions")     
session_london = input.session("1245-2145", "London Session", group="Sessions") 
session_ny     = input.session("1745-0245", "New York Session", group="Sessions")

extDist = input.int(50, "Extension Distance (Bars)", minval=0, maxval=200, group="Sessions")

timezone = "Asia/Kathmandu"

// ==========================================
// DAY CHANGE LOGIC (RESET DAILY)
// ==========================================
var int prevDayKey = na
currentDayKey = year * 10000 + month * 100 + dayofmonth
isNewDay = currentDayKey != prevDayKey

// ==========================================
// ASIA SESSION STATE
// ==========================================
var float asiaHigh = na
var float asiaLow = na
var int asiaHighBar = na
var int asiaLowBar = na
var line asiaHLine = na
var line asiaLLine = na
var label asiaLbl = na

// ==========================================
// LONDON SESSION STATE
// ==========================================
var float lonHigh = na
var float lonLow = na
var int lonHighBar = na
var int lonLowBar = na
var line lonHLine = na
var line lonLLine = na
var label lonLbl = na

// ==========================================
// NEW YORK SESSION STATE
// ==========================================
var float nyHigh = na
var float nyLow = na
var int nyHighBar = na
var int nyLowBar = na
var line nyHLine = na
var line nyLLine = na
var label nyLbl = na

// ==========================================
// CLEANUP ON NEW DAY
// ==========================================
if isNewDay
    // Delete Asia
    line.delete(asiaHLine)
    line.delete(asiaLLine)
    label.delete(asiaLbl)
    asiaHigh := na
    asiaLow := na
    asiaHighBar := na
    asiaLowBar := na
    asiaHLine := na
    asiaLLine := na
    asiaLbl := na
    
    // Delete London
    line.delete(lonHLine)
    line.delete(lonLLine)
    label.delete(lonLbl)
    lonHigh := na
    lonLow := na
    lonHighBar := na
    lonLowBar := na
    lonHLine := na
    lonLLine := na
    lonLbl := na
    
    // Delete NY
    line.delete(nyHLine)
    line.delete(nyLLine)
    label.delete(nyLbl)
    nyHigh := na
    nyLow := na
    nyHighBar := na
    nyLowBar := na
    nyHLine := na
    nyLLine := na
    nyLbl := na
    
    prevDayKey := currentDayKey

// ==========================================
// ASIA SESSION
// ==========================================
inAsia = not na(time(timeframe.period, session_asia, timezone))

if inAsia and not inAsia[1]
    // Session starts - initialize
    asiaHigh := high
    asiaLow := low
    asiaHighBar := bar_index
    asiaLowBar := bar_index

else if inAsia
    // During session - update high/low
    if high > asiaHigh
        asiaHigh := high
        asiaHighBar := bar_index
    if low < asiaLow
        asiaLow := low
        asiaLowBar := bar_index

// Draw/update Asia high line
if inAsia or (not inAsia and not na(asiaHigh))
    if na(asiaHLine) and not na(asiaHigh)
        asiaHLine := line.new(asiaHighBar, asiaHigh, bar_index + extDist, asiaHigh, color=colorAsia, width=lineWidth, extend=extend.right)
        asiaLbl := label.new(asiaHighBar, asiaHigh, "A", color=colorAsia, style=label.style_label_up, yloc=yloc.abovebar, textcolor=color.white, size=labelSize)
    else if not na(asiaHLine)
        line.set_xy1(asiaHLine, asiaHighBar, asiaHigh)
        line.set_xy2(asiaHLine, bar_index + extDist, asiaHigh)
        label.set_xy(asiaLbl, asiaHighBar, asiaHigh)

// Draw/update Asia low line
if inAsia or (not inAsia and not na(asiaLow))
    if na(asiaLLine) and not na(asiaLow)
        asiaLLine := line.new(asiaLowBar, asiaLow, bar_index + extDist, asiaLow, color=colorAsia, width=lineWidth, extend=extend.right)
    else if not na(asiaLLine)
        line.set_xy1(asiaLLine, asiaLowBar, asiaLow)
        line.set_xy2(asiaLLine, bar_index + extDist, asiaLow)

// ==========================================
// LONDON SESSION
// ==========================================
inLon = not na(time(timeframe.period, session_london, timezone))

if inLon and not inLon[1]
    // Session starts - initialize
    lonHigh := high
    lonLow := low
    lonHighBar := bar_index
    lonLowBar := bar_index

else if inLon
    // During session - update high/low
    if high > lonHigh
        lonHigh := high
        lonHighBar := bar_index
    if low < lonLow
        lonLow := low
        lonLowBar := bar_index

// Draw/update London high line
if inLon or (not inLon and not na(lonHigh))
    if na(lonHLine) and not na(lonHigh)
        lonHLine := line.new(lonHighBar, lonHigh, bar_index + extDist, lonHigh, color=colorLondon, width=lineWidth, extend=extend.right)
        lonLbl := label.new(lonHighBar, lonHigh, "L", color=colorLondon, style=label.style_label_up, yloc=yloc.abovebar, textcolor=color.white, size=labelSize)
    else if not na(lonHLine)
        line.set_xy1(lonHLine, lonHighBar, lonHigh)
        line.set_xy2(lonHLine, bar_index + extDist, lonHigh)
        label.set_xy(lonLbl, lonHighBar, lonHigh)

// Draw/update London low line
if inLon or (not inLon and not na(lonLow))
    if na(lonLLine) and not na(lonLow)
        lonLLine := line.new(lonLowBar, lonLow, bar_index + extDist, lonLow, color=colorLondon, width=lineWidth, extend=extend.right)
    else if not na(lonLLine)
        line.set_xy1(lonLLine, lonLowBar, lonLow)
        line.set_xy2(lonLLine, bar_index + extDist, lonLow)

// ==========================================
// NEW YORK SESSION
// ==========================================
inNY = not na(time(timeframe.period, session_ny, timezone))

if inNY and not inNY[1]
    // Session starts - initialize
    nyHigh := high
    nyLow := low
    nyHighBar := bar_index
    nyLowBar := bar_index

else if inNY
    // During session - update high/low
    if high > nyHigh
        nyHigh := high
        nyHighBar := bar_index
    if low < nyLow
        nyLow := low
        nyLowBar := bar_index

// Draw/update NY high line
if inNY or (not inNY and not na(nyHigh))
    if na(nyHLine) and not na(nyHigh)
        nyHLine := line.new(nyHighBar, nyHigh, bar_index + extDist, nyHigh, color=colorNY, width=lineWidth, extend=extend.right)
        nyLbl := label.new(nyHighBar, nyHigh, "N", color=colorNY, style=label.style_label_up, yloc=yloc.abovebar, textcolor=color.white, size=labelSize)
    else if not na(nyHLine)
        line.set_xy1(nyHLine, nyHighBar, nyHigh)
        line.set_xy2(nyHLine, bar_index + extDist, nyHigh)
        label.set_xy(nyLbl, nyHighBar, nyHigh)

// Draw/update NY low line
if inNY or (not inNY and not na(nyLow))
    if na(nyLLine) and not na(nyLow)
        nyLLine := line.new(nyLowBar, nyLow, bar_index + extDist, nyLow, color=colorNY, width=lineWidth, extend=extend.right)
    else if not na(nyLLine)
        line.set_xy1(nyLLine, nyLowBar, nyLow)
        line.set_xy2(nyLLine, bar_index + extDist, nyLow)
